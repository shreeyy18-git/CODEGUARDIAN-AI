# ── CodeGuardian AI — Environment template ──────────────────────────────
# Copy to ".env" and fill in real values:  cp .env.example .env
# -----------------------------------------------------------------------

# ── LLM providers ──────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"

GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=30

# ── GitHub integration ─────────────────────────────────────────────────
# Personal access token with repo:status + checks:write scopes
GITHUB_TOKEN="your-github-pat-here"
# Shared secret configured in the GitHub webhook settings
GITHUB_WEBHOOK_SECRET="your-webhook-secret-here"

# ── LangSmith observability ────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY="your-langsmith-api-key-here"
LANGCHAIN_PROJECT=codeguardian-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./review.db

# ── Review pipeline ────────────────────────────────────────────────────
MAX_DIFF_CHARS=40000

# ── Risk scoring thresholds (0.0–1.0, higher = safer) ───────────────────
RISK_PASS_THRESHOLD=0.8
RISK_WARN_THRESHOLD=0.4

# ── Server ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ── Static analysis toggles ────────────────────────────────────────────
ENABLE_SEMGREP=true
ENABLE_BANDIT=true
ENABLE_RUFF=true
